# Upstash Redis (rate limiting em produção)
# Crie um banco em https://console.upstash.com e copie as credenciais REST.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Chave AES-256 para criptografar totpSecret em repouso (32 bytes em base64).
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOTP_ENCRYPTION_KEY=
