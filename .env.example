# Upstash Redis (rate limiting em produção)
# Crie um banco em https://console.upstash.com e copie as credenciais REST.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Auth.js / NextAuth
AUTH_SECRET=
# URL pública do eight (produção)
AUTH_URL=https://doctor8.com.br
NEXT_PUBLIC_SITE_URL=https://doctor8.com.br

# Login Doctor8 (OIDC) — app principal em app.doctor8.org
AUTH_DOCTOR8_ID=eight
AUTH_DOCTOR8_SECRET=
AUTH_DOCTOR8_ISSUER=https://app.doctor8.org

# Chave AES-256 para criptografar totpSecret em repouso (32 bytes em base64).
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOTP_ENCRYPTION_KEY=

# S3 / object storage (opcional)
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# URL pública do CDN/bucket — APENAS para avatares e mídia de posts (uploads/).
# Documentos de verificação NÃO usam esta variável; acesso via URL assinada (15 min).
S3_PUBLIC_URL=
