generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js ───────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Usuário e perfil ─────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  isAdmin       Boolean   @default(false)
  totpSecret    String?
  totpEnabled   Boolean   @default(false)
  totpLastUsed  String?
  // Incrementado a cada reset de senha (e disponível pra outros eventos
  // sensíveis no futuro). Sessões JWT emitidas com uma versão menor são
  // consideradas inválidas — força novo login em todos os dispositivos.
  sessionVersion Int      @default(0)
  locale        String    @default("pt")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  invitesSent   Invite[]  @relation("InviteCreator")
  inviteUsed    Invite?   @relation("InviteUser")
}

model Invite {
  id          String    @id @default(cuid())
  email       String
  code        String    @unique
  createdById String?
  usedAt      DateTime?
  usedById    String?   @unique
  emailSentAt DateTime?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  createdBy User? @relation("InviteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  usedBy    User? @relation("InviteUser", fields: [usedById], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([code])
}

model Profile {
  id                  String    @id @default(cuid())
  userId              String    @unique
  handle              String    @unique
  displayName         String
  bio                 String?   @db.VarChar(160)
  specialty           String?
  registrationType    String?
  registrationNumber  String?
  registrationCountry String?
  location            String?
  avatarUrl           String?
  bannerUrl           String?
  verified                Boolean            @default(false)
  verificationStatus      VerificationStatus @default(PENDING)
  verificationDocumentUrl String?
  verificationSubmittedAt DateTime?
  verificationReviewedAt  DateTime?
  rejectionReason         String?            @db.VarChar(300)
  verifiedAt              DateTime?
  verifiedViaDoctor8      Boolean            @default(false)
  pinnedPostId        String?   @unique
  teleconsultUrl       String?
  notifyLike           Boolean            @default(true)
  notifyRepost         Boolean            @default(true)
  notifyFollow         Boolean            @default(true)
  notifyReply          Boolean            @default(true)
  notifyMention        Boolean            @default(true)
  notifyMessage        Boolean            @default(true)
  notifyEmail          Boolean            @default(false)
  suspended            Boolean            @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  pinnedPost Post? @relation("ProfilePinned", fields: [pinnedPostId], references: [id], onDelete: SetNull)

  posts              Post[]
  likes              Like[]
  reposts            Repost[]
  pollVotes          PollVote[]
  followers          Follow[]       @relation("following")
  following          Follow[]       @relation("follower")
  blocksSent         Block[]        @relation("blocksSent")
  blocksReceived     Block[]        @relation("blocksReceived")
  mutesSent          Mute[]         @relation("mutesSent")
  mutesReceived      Mute[]         @relation("mutesReceived")
  notifications      Notification[] @relation("recipient")
  actorNotifications Notification[] @relation("actor")
  conversations      ConversationParticipant[]
  directMessages     DirectMessage[]
  ownedLists         ProfileList[]         @relation("ownedLists")
  listMemberships    ProfileListMember[]
  groupConversationsCreated Conversation[] @relation("groupCreator")
  viewsReceived      ProfileView[]         @relation("viewsReceived")
  viewsMade          ProfileView[]         @relation("viewsMade")
  reportsSent        Report[]              @relation("reportsSent")
  reportsReceived    Report[]              @relation("reportsReceived")
  bookmarks          Bookmark[]
  pushSubscriptions  PushSubscription[]
  postViewsMade      PostView[]
  mutedWords         MutedWord[]
  listFollows        ListFollow[]
  messageRequestsSent     MessageRequest[] @relation("messageRequestsSent")
  messageRequestsReceived MessageRequest[] @relation("messageRequestsReceived")
}

// ─── Posts e conteúdo (feed estilo X) ────────────────────────────────────

model Post {
  id          String    @id @default(cuid())
  authorId    String
  body        String    @db.VarChar(500)
  parentId    String?
  repostOfId  String?
  images      String[]  @default([])
  videoUrl    String?
  gifUrl      String?
  scheduledAt DateTime?
  editedAt    DateTime?
  threadId    String?
  threadOrder Int       @default(0)
  linkUrl     String?
  linkTitle   String?
  linkDesc    String?   @db.VarChar(300)
  linkImage   String?
  isClinicalCase Boolean  @default(false)
  caseTags       String[] @default([])
  caseSpecialty  String?
  caseReviewedAt DateTime?
  hidden         Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author        Profile       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent        Post?         @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Post[]        @relation("Replies")
  repostOf      Post?         @relation("RepostChain", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts       Post[]        @relation("RepostChain")
  threadRoot    Post?         @relation("ThreadPosts", fields: [threadId], references: [id], onDelete: SetNull)
  threadParts   Post[]        @relation("ThreadPosts")
  pinnedOn      Profile?      @relation("ProfilePinned")
  poll          Poll?
  hashtags      PostHashtag[]
  likes         Like[]
  repostRecords Repost[]
  bookmarks     Bookmark[]
  reports       Report[]
  views         PostView[]
  edits         PostEdit[]

  @@index([authorId, createdAt])
  @@index([threadId])
  @@index([scheduledAt])
  @@index([isClinicalCase, createdAt])
}

model Conversation {
  id          String   @id @default(cuid())
  isGroup     Boolean  @default(false)
  name        String?  @db.VarChar(80)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy    Profile?                  @relation("groupCreator", fields: [createdById], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     DirectMessage[]

  @@index([updatedAt])
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  profileId      String
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  profile      Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([conversationId, profileId])
  @@index([profileId])
}

model DirectMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String   @db.VarChar(2000)
  imageUrl       String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Profile      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Poll {
  id        String       @id @default(cuid())
  postId    String       @unique
  endsAt    DateTime
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  options   PollOption[]
  votes     PollVote[]
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String
  text      String     @db.VarChar(100)
  sortOrder Int        @default(0)
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     PollVote[]
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  optionId  String
  profileId String
  createdAt DateTime   @default(now())
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  profile   Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, pollId])
}

model Hashtag {
  id        String        @id @default(cuid())
  tag       String        @unique
  posts     PostHashtag[]
  createdAt DateTime      @default(now())
}

model PostHashtag {
  postId    String
  hashtagId String
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag   Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@id([postId, hashtagId])
  @@index([hashtagId])
}

model Like {
  id        String   @id @default(cuid())
  profileId String
  postId    String
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([profileId, postId])
}

model Repost {
  id        String   @id @default(cuid())
  profileId String
  postId    String
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([profileId, postId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  Profile @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following Profile @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker Profile @relation("blocksSent", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked Profile @relation("blocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model Mute {
  id        String   @id @default(cuid())
  muterId   String
  mutedId   String
  createdAt DateTime @default(now())

  muter Profile @relation("mutesSent", fields: [muterId], references: [id], onDelete: Cascade)
  muted Profile @relation("mutesReceived", fields: [mutedId], references: [id], onDelete: Cascade)

  @@unique([muterId, mutedId])
  @@index([mutedId])
}

model Notification {
  id             String           @id @default(cuid())
  recipientId    String
  actorId        String
  type           NotificationType
  postId         String?
  conversationId String?
  groupName      String?          @db.VarChar(80)
  dedupeKey      String?          @unique
  read           Boolean          @default(false)
  createdAt      DateTime         @default(now())

  recipient Profile @relation("recipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     Profile @relation("actor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt])
}

model MutedWord {
  id        String   @id @default(cuid())
  profileId String
  word      String   @db.VarChar(50)
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, word])
  @@index([profileId])
}

enum NotificationType {
  LIKE
  REPOST
  FOLLOW
  REPLY
  MENTION
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  MESSAGE
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model ProfileList {
  id          String   @id @default(cuid())
  ownerId     String
  name        String   @db.VarChar(80)
  description String?  @db.VarChar(160)
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())

  owner     Profile             @relation("ownedLists", fields: [ownerId], references: [id], onDelete: Cascade)
  members   ProfileListMember[]
  followers ListFollow[]

  @@index([ownerId])
  @@index([isPublic])
}

model ListFollow {
  profileId String
  listId    String
  createdAt DateTime @default(now())

  profile Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  list    ProfileList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([profileId, listId])
  @@index([profileId])
  @@index([listId])
}

model ProfileListMember {
  listId    String
  profileId String
  addedAt   DateTime @default(now())

  list    ProfileList @relation(fields: [listId], references: [id], onDelete: Cascade)
  profile Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([listId, profileId])
}

model ProfileView {
  id        String   @id @default(cuid())
  profileId String
  viewerId  String
  createdAt DateTime @default(now())

  profile Profile @relation("viewsReceived", fields: [profileId], references: [id], onDelete: Cascade)
  viewer  Profile @relation("viewsMade", fields: [viewerId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt])
}

enum ReportTarget {
  POST
  PROFILE
}

enum ReportReason {
  SPAM
  HARASSMENT
  MISINFORMATION
  PRIVACY
  OTHER
}

model Report {
  id              String       @id @default(cuid())
  reporterId      String
  targetType      ReportTarget
  targetId        String
  targetPostId    String?
  targetProfileId String?
  reason          ReportReason
  details         String?      @db.VarChar(500)
  reviewedAt      DateTime?
  createdAt       DateTime     @default(now())

  reporter        Profile  @relation("reportsSent", fields: [reporterId], references: [id], onDelete: Cascade)
  targetPost      Post?    @relation(fields: [targetPostId], references: [id], onDelete: SetNull)
  reportedProfile Profile? @relation("reportsReceived", fields: [targetProfileId], references: [id], onDelete: SetNull)

  @@unique([reporterId, targetType, targetId])
  @@index([targetType, targetId, createdAt])
  @@index([reviewedAt, createdAt])
}

model Bookmark {
  profileId String
  postId    String
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  post    Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([profileId, postId])
  @@index([profileId, createdAt])
}

model PostView {
  id        String   @id @default(cuid())
  postId    String
  viewerId  String
  createdAt DateTime @default(now())

  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  viewer Profile @relation(fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([postId, viewerId])
  @@index([postId])
}

model PostEdit {
  id       String   @id @default(cuid())
  postId   String
  body     String   @db.VarChar(500)
  editedAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, editedAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  profileId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

enum MessageRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model MessageRequest {
  id          String               @id @default(cuid())
  fromId      String
  toId        String
  body        String               @db.VarChar(300)
  status      MessageRequestStatus @default(PENDING)
  createdAt   DateTime             @default(now())
  respondedAt DateTime?

  from Profile @relation("messageRequestsSent", fields: [fromId], references: [id], onDelete: Cascade)
  to   Profile @relation("messageRequestsReceived", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
  @@index([toId, status, createdAt])
}
